<Window x:Class="AutoTimer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:AutoTimer.Controls"
        Title="AutoTimer Settings"
        MinWidth="480" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        FontFamily="pack://application:,,,/Assets/#NanumSquare Neo Regular"
        FontSize="15"
        MouseLeftButtonDown="OnTitleBarDrag">

    <Window.Resources>
        <FontFamily x:Key="AppFont">pack://application:,,,/Assets/#NanumSquare Neo Regular</FontFamily>

        <!-- ===== 토글 스위치 ===== -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ContentPresenter VerticalAlignment="Center" Margin="0,0,10,0"
                                              TextBlock.Foreground="{DynamicResource FgBrush}"
                                              TextBlock.FontFamily="pack://application:,,,/Assets/#NanumSquare Neo Regular"
                                              TextBlock.FontSize="15"/>
                            <Grid Width="48" Height="22" Cursor="Hand">
                                <Border x:Name="Track" CornerRadius="11"
                                        Background="{DynamicResource BgHoverBrush}" BorderThickness="1"
                                        BorderBrush="{DynamicResource BorderBrush}"/>
                                <Border x:Name="OnLabel" CornerRadius="11"
                                        Background="{DynamicResource AccentDimBrush}" Opacity="0"/>
                                <TextBlock x:Name="StateText" Text="OFF"
                                           Foreground="{DynamicResource FgDimBrush}"
                                           FontSize="9" FontWeight="Bold" FontFamily="{StaticResource AppFont}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Margin="0,0,7,0"/>
                                <Ellipse x:Name="Thumb" Width="16" Height="16"
                                         Fill="{DynamicResource FgDimBrush}" HorizontalAlignment="Left"
                                         Margin="3,0,0,0"/>
                            </Grid>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="OnLabel" Property="Opacity" Value="1"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                                <Setter TargetName="StateText" Property="Text" Value="ON"/>
                                <Setter TargetName="StateText" Property="HorizontalAlignment" Value="Left"/>
                                <Setter TargetName="StateText" Property="Margin" Value="7,0,0,0"/>
                                <Setter TargetName="StateText" Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== 텍스트박스 ===== -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource BgInputBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource AccentDimBrush}"/>
        </Style>

        <!-- ===== 콤보박스 (완전 커스텀 — 드롭다운 포함) ===== -->
        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="24"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" CornerRadius="0"
                        Background="{DynamicResource BgInputBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                <Path x:Name="Arrow" Grid.Column="1" Fill="{DynamicResource AccentBrush}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M0,0 L4,4 8,0"/>
            </Grid>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Template="{StaticResource ComboBoxToggleButton}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press"/>
                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,4,28,4" VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              TextBlock.Foreground="{DynamicResource AccentBrush}"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   Focusable="False" AllowsTransparency="True">
                                <Border Background="{DynamicResource BgPanelBrush}"
                                        BorderBrush="{DynamicResource AccentDimBrush}"
                                        BorderThickness="1" CornerRadius="0"
                                        MaxHeight="200" MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource FgBrush}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentDimBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== 버튼 ===== -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BgPanelBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentDimBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentDimBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== 세그먼트 라디오 ===== -->
        <Style x:Key="SegmentRadio" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{DynamicResource BgPanelBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="3" Padding="10,4" Cursor="Hand">
                            <ContentPresenter x:Name="Cp" HorizontalAlignment="Center"
                                              TextBlock.FontFamily="{DynamicResource AppFont}" TextBlock.FontSize="14"
                                              TextBlock.Foreground="{DynamicResource FgBrush}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentDimBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Cp" Property="TextBlock.Foreground" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Cp" Property="TextBlock.FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="Margin" Value="0,14,0,4"/>
        </Style>

        <Style x:Key="SectionLine" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AccentDimBrush}"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Opacity" Value="0.4"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FgBrush}"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ===== 미니 토글 (스케줄 행용) ===== -->
        <Style x:Key="MiniToggle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="40" Height="18" Cursor="Hand">
                            <Border x:Name="Track" CornerRadius="9"
                                    Background="{DynamicResource BgHoverBrush}" BorderThickness="1"
                                    BorderBrush="{DynamicResource BorderBrush}"/>
                            <Border x:Name="OnBg" CornerRadius="9"
                                    Background="{DynamicResource AccentDimBrush}" Opacity="0"/>
                            <TextBlock x:Name="St" Text="OFF" Foreground="{DynamicResource FgDimBrush}"
                                       FontSize="8" FontWeight="Bold" FontFamily="{StaticResource AppFont}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <Ellipse x:Name="Th" Width="12" Height="12"
                                     Fill="{DynamicResource FgDimBrush}" HorizontalAlignment="Left" Margin="3,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="OnBg" Property="Opacity" Value="1"/>
                                <Setter TargetName="Th" Property="Fill" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Th" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Th" Property="Margin" Value="0,0,3,0"/>
                                <Setter TargetName="St" Property="Text" Value="ON"/>
                                <Setter TargetName="St" Property="HorizontalAlignment" Value="Left"/>
                                <Setter TargetName="St" Property="Margin" Value="5,0,0,0"/>
                                <Setter TargetName="St" Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeleteBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource RedBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="3" Padding="4,2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30FF4060"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- ===== 스크롤바 ===== -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
        </Style>
        <Style x:Key="{x:Type ScrollViewer}" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter/>
                            <ScrollBar Grid.Column="1" Name="PART_VerticalScrollBar"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Width="6" Margin="0,2,2,2" Opacity="0.4"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource AccentDimBrush}" BorderThickness="1" CornerRadius="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 커스텀 타이틀바 -->
            <Border Grid.Row="0" Background="{DynamicResource BgPanelBrush}" MouseLeftButtonDown="OnTitleBarDrag">
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#x2699;" Foreground="{DynamicResource AccentBrush}" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="AutoTimer" Foreground="{DynamicResource AccentBrush}"
                                   FontFamily="{StaticResource AppFont}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <ComboBox x:Name="CmbLanguage" Width="95" Margin="0,0,6,0"
                                  SelectionChanged="OnLanguageChanged"/>
                        <ComboBox x:Name="CmbTheme" Width="85"
                                  SelectionChanged="OnThemeChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="&#x2012;" Padding="8,2" FontSize="14" BorderThickness="0"
                                Background="Transparent" Click="OnMinimize" Margin="0,0,2,0"/>
                        <Button Content="&#x2715;" Padding="8,2" FontSize="14" BorderThickness="0"
                                Background="Transparent" Foreground="{DynamicResource RedBrush}" Click="OnCloseWindow"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="18,12,18,16">

                    <!-- 헤더 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="AutoTimer" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}" FontFamily="{StaticResource AppFont}"/>
                        <TextBlock x:Name="TxtSubtitle" Text=" Settings" FontSize="20"
                                   Foreground="{DynamicResource FgDimBrush}" FontFamily="{StaticResource AppFont}"/>
                    </StackPanel>

                    <!-- 일반 -->
                    <TextBlock x:Name="LblGeneral" Style="{StaticResource SectionHeader}"/>
                    <Border Style="{StaticResource SectionLine}"/>

                    <CheckBox x:Name="ChkRunOnStartup" Style="{StaticResource ToggleSwitch}" Margin="0,4"/>

                    <StackPanel Orientation="Horizontal" Margin="0,6">
                        <TextBlock x:Name="LblTimeSource" Style="{StaticResource Label}" Width="120"/>
                        <RadioButton x:Name="RbServer" GroupName="TimeSource" Style="{StaticResource SegmentRadio}" Margin="0,0,4,0"/>
                        <RadioButton x:Name="RbLocal" GroupName="TimeSource" Style="{StaticResource SegmentRadio}"/>
                    </StackPanel>

                    <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="4" Padding="12,8" Margin="0,6">
                        <TextBlock x:Name="TxtCurrentTime" FontFamily="{StaticResource AppFont}" FontSize="18"
                                   Foreground="{DynamicResource AccentBrush}"/>
                    </Border>


                    <!-- 화면 -->
                    <TextBlock x:Name="LblDisplay" Style="{StaticResource SectionHeader}"/>
                    <Border Style="{StaticResource SectionLine}"/>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LblMonitor" Style="{StaticResource Label}"/>
                        <ComboBox x:Name="CmbMonitor" Grid.Column="1"/>
                        <Button x:Name="BtnRefreshMonitor" Content="&#x21BB;" Grid.Column="2"
                                Margin="4,0,0,0" Padding="8,4" FontSize="14"
                                Click="OnRefreshMonitors" ToolTip="Refresh"/>
                    </Grid>

                    <!-- 재생 -->
                    <TextBlock x:Name="LblPlayback" Style="{StaticResource SectionHeader}"/>
                    <Border Style="{StaticResource SectionLine}"/>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LblDefaultVideo" Style="{StaticResource Label}"/>
                        <TextBox x:Name="TxtVideoPath" Grid.Column="1" IsReadOnly="True"/>
                        <Button Content="..." Grid.Column="2" Margin="4,0,0,0" Padding="8,4"
                                Click="OnBrowseVideo"/>
                    </Grid>

                    <!-- 주간 스케줄 -->
                    <TextBlock x:Name="LblWeekly" Style="{StaticResource SectionHeader}"/>
                    <Border Style="{StaticResource SectionLine}"/>

                    <ItemsControl x:Name="WeeklyList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="3"
                                        Padding="6,4" Margin="0,2"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="56"/>
                                            <ColumnDefinition Width="72"/>
                                            <ColumnDefinition Width="68"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="28"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox IsChecked="{Binding Enabled}" Style="{StaticResource MiniToggle}"
                                                  VerticalAlignment="Center" Margin="2,0"/>
                                        <ComboBox Grid.Column="1" SelectedItem="{Binding DayOfWeekDisplay}"
                                                  ItemsSource="{Binding DayOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  FontSize="14" Padding="2,4" VerticalAlignment="Center" Height="30"/>
                                        <ctrl:TimePicker Grid.Column="2" Time="{Binding Time}"
                                                         VerticalAlignment="Center" Height="30" Margin="3,0"/>
                                        <TextBox Grid.Column="3" Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="14" Padding="2,4" Margin="3,0"
                                                 VerticalAlignment="Center" Height="30"/>
                                        <Button Grid.Column="4" Content="X" Style="{StaticResource DeleteBtn}"
                                                Tag="{Binding Id}" Click="OnDeleteWeekly" FontSize="14" Padding="2,1"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button x:Name="BtnAddWeekly" HorizontalAlignment="Right" Margin="0,6,0,0"
                            Click="OnAddWeekly" FontSize="14"/>

                    <!-- 일회성 -->
                    <TextBlock x:Name="LblOneTime" Style="{StaticResource SectionHeader}"/>
                    <Border Style="{StaticResource SectionLine}"/>

                    <ItemsControl x:Name="OneTimeList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="3"
                                        Padding="8,5" Margin="0,2"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="112"/>
                                            <ColumnDefinition Width="68"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="28"/>
                                        </Grid.ColumnDefinitions>
                                        <ctrl:DatePicker Date="{Binding Date}"
                                                         VerticalAlignment="Center" Height="30"/>
                                        <ctrl:TimePicker Grid.Column="1" Time="{Binding Time}"
                                                         VerticalAlignment="Center" Height="30" Margin="3,0"/>
                                        <TextBox Grid.Column="2" Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="14" Padding="2,4" Margin="3,0"
                                                 VerticalAlignment="Center" Height="30"/>
                                        <Button Grid.Column="3" Content="X" Style="{StaticResource DeleteBtn}"
                                                Tag="{Binding Id}" Click="OnDeleteOneTime" FontSize="14"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button x:Name="BtnAddOneTime" HorizontalAlignment="Right" Margin="0,6,0,0"
                            Click="OnAddOneTime" FontSize="14"/>

                    <!-- 하단 -->
                    <Border Background="{DynamicResource AccentDimBrush}" Height="1" Opacity="0.3" Margin="0,16,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                        <Button x:Name="BtnTestPlay" Padding="16,7" Click="OnTestPlay"/>
                        <Button x:Name="BtnSync" Padding="16,7" Margin="10,0" Click="OnSync"/>
                        <Button x:Name="BtnSave" Padding="20,7" Click="OnSave" FontWeight="Bold"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- 피커 오버레이 (클릭 시 닫기용 배경 + 피커 패널) -->
            <Grid x:Name="PickerOverlay" Grid.Row="1" Visibility="Collapsed">
                <!-- 반투명 배경 — 클릭하면 피커 닫힘 -->
                <Border Background="#80000000" MouseLeftButtonUp="OnOverlayClick"/>

                <!-- 시간 피커 -->
                <Border x:Name="TimePickerPanel" Visibility="Collapsed"
                        Background="{DynamicResource BgPanelBrush}"
                        BorderBrush="{DynamicResource AccentDimBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="16,12"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <StackPanel>
                                <RepeatButton Content="▲" Click="OnHourUp" FontSize="16" Padding="14,4" Foreground="{DynamicResource FgBrush}"
                                              Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                <TextBlock x:Name="TxtPickerHour" Text="00" FontSize="32" FontWeight="Bold"
                                           Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"
                                           FontFamily="pack://application:,,,/Assets/#NanumSquare Neo Regular"
                                           Margin="0,6" Width="56" TextAlignment="Center"/>
                                <RepeatButton Content="▼" Click="OnHourDown" FontSize="16" Padding="14,4" Foreground="{DynamicResource FgBrush}"
                                              Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>
                            <TextBlock Text=":" FontSize="32" FontWeight="Bold" Margin="8,30"
                                       Foreground="{DynamicResource FgDimBrush}"/>
                            <StackPanel>
                                <RepeatButton Content="▲" Click="OnMinUp" FontSize="16" Padding="14,4" Foreground="{DynamicResource FgBrush}"
                                              Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                <TextBlock x:Name="TxtPickerMin" Text="00" FontSize="32" FontWeight="Bold"
                                           Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"
                                           FontFamily="pack://application:,,,/Assets/#NanumSquare Neo Regular"
                                           Margin="0,6" Width="56" TextAlignment="Center"/>
                                <RepeatButton Content="▼" Click="OnMinDown" FontSize="16" Padding="14,4" Foreground="{DynamicResource FgBrush}"
                                              Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>
                        </StackPanel>
                        <Button x:Name="BtnTimeOk" Content="확인" Click="OnTimeOk" Margin="0,10,0,0"
                                Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"
                                Padding="20,6"/>
                    </StackPanel>
                </Border>

                <!-- 날짜 피커 -->
                <Border x:Name="DatePickerPanel" Visibility="Collapsed"
                        Background="{DynamicResource BgPanelBrush}"
                        BorderBrush="{DynamicResource AccentDimBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="12,10"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="◀" Click="OnDatePrevMonth" Style="{StaticResource DeleteBtn}"
                                    FontSize="16" Padding="10,4" Foreground="{DynamicResource FgBrush}"/>
                            <TextBlock x:Name="TxtDateYearMonth" Grid.Column="1" FontSize="17" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="pack://application:,,,/Assets/#NanumSquare Neo Regular"/>
                            <Button Content="▶" Grid.Column="2" Click="OnDateNextMonth" Style="{StaticResource DeleteBtn}"
                                    FontSize="16" Padding="10,4" Foreground="{DynamicResource FgBrush}"/>
                        </Grid>
                        <UniformGrid x:Name="DateDayHeaders" Rows="1" Columns="7" Margin="0,0,0,4"/>
                        <UniformGrid x:Name="DateDayGrid" Rows="6" Columns="7"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
