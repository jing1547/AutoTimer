<Window x:Class="AutoTimer.Controls.PrePlaybackNotification"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Topmost="True" Title="AutoTimer"
        Width="360" Height="200"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="0" BorderThickness="1"
            BorderBrush="{DynamicResource AccentDimBrush}"
            Background="{DynamicResource BgPanelBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 타이틀 -->
            <Border Grid.Row="0" Background="{DynamicResource BgHoverBrush}" Padding="16,10">
                <TextBlock Text="AutoTimer" FontSize="15" FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}"
                           FontFamily="pack://application:,,,/Assets/#NanumSquare Neo Regular"/>
            </Border>

            <!-- 메시지 -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="TxtMessage" TextWrapping="Wrap" TextAlignment="Center"
                           Foreground="{DynamicResource FgBrush}" FontSize="14" LineHeight="22"
                           FontFamily="pack://application:,,,/Assets/#NanumSquare Neo Regular"/>
            </StackPanel>

            <!-- 버튼 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Center" Margin="16,4,16,16">
                <Button x:Name="BtnOk" MinWidth="80" Padding="16,7"
                        Cursor="Hand" FontSize="14" Click="BtnOk_Click"
                        FontFamily="pack://application:,,,/Assets/#NanumSquare Neo Regular"/>
                <Button x:Name="BtnCancel" MinWidth="80" Padding="16,7" Margin="8,0,0,0"
                        Cursor="Hand" FontSize="14" Click="BtnCancel_Click"
                        FontFamily="pack://application:,,,/Assets/#NanumSquare Neo Regular"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
