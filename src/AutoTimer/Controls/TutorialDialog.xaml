<Window x:Class="AutoTimer.Controls.TutorialDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Width="500" Height="520"
        FontFamily="pack://application:,,,/Assets/#NanumSquare Neo Regular"
        FontSize="14">

    <Window.Resources>
        <!-- 버튼 -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BgPanelBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentDimBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontFamily" Value="pack://application:,,,/Assets/#NanumSquare Neo Regular"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentDimBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 스크롤바 -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
        </Style>
        <Style x:Key="{x:Type ScrollViewer}" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter/>
                            <ScrollBar Grid.Column="1" Name="PART_VerticalScrollBar"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Width="6" Margin="0,2,2,2" Opacity="0.4"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="0"
            BorderBrush="{DynamicResource AccentDimBrush}" BorderThickness="1"
            Background="{DynamicResource BgPanelBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 타이틀 -->
            <Border Grid.Row="0" Background="{DynamicResource BgHoverBrush}" Padding="16,10">
                <TextBlock x:Name="TxtTitle" Text="AutoTimer" FontSize="15" FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}"
                           FontFamily="pack://application:,,,/Assets/#NanumSquare Neo Regular"/>
            </Border>

            <!-- 내용 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0">
                <TextBlock x:Name="TxtContent" TextWrapping="Wrap"
                           Foreground="{DynamicResource FgBrush}" Margin="20,16,20,16"
                           FontFamily="pack://application:,,,/Assets/#NanumSquare Neo Regular"
                           FontSize="13.5" LineHeight="22"/>
            </ScrollViewer>

            <!-- 닫기 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Center" Margin="16,4,16,16">
                <Button x:Name="BtnClose" Content="OK" MinWidth="80"
                        Padding="16,7" Click="OnClose"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
